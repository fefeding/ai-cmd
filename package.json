{
  "name": "@fefeding/aicmd",
  "version": "0.1.15",
  "private": false,
  "type": "commonjs",
  "description": "AI-powered web SSH terminal with autonomous agent, skills, and file transfer",
  "repository": {
    "type": "git",
    "url": "https://github.com/fefeding/ai-cmd"
  },
  "main": "electron/main.js",
  "files": [
    "bin/",
    "public/",
    "dist/",
    "electron/",
    "data/skills",
    "patches",
    "server.js",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "start": "pm2 start server.js --name aicmd-server --disable-logs --",
    "restart": "pm2 restart aicmd-server --disable-logs --",
    "stop": "pm2 stop aicmd-server --",
    "dev": "vite",
    "build": "npm run build-only",
    "preview": "vite preview",
    "build-only": "vite build && npm run build-server",
    "build-server": "tsc -p tsconfig.server.json",
    "type-check": "vue-tsc --noEmit --composite false",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "electron:dev": "node scripts/electron-dev.js",
    "electron:build": "node scripts/electron-build.js",
    "electron:build:win": "node scripts/electron-build.js --platform=win",
    "electron:build:mac": "node scripts/electron-build.js --platform=mac",
    "electron:build:linux": "node scripts/electron-build.js --platform=linux"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "cpu-features": "^0.0.10",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "node-pty": "1.2.0-beta.13",
    "ssh2": "^1.17.0",
    "uuid": "^13.0.2",
    "vue-i18n": "^11.4.4",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@electron/rebuild": "^4.0.4",
    "@fefeding/eventemitter": "^1.0.5",
    "@fefeding/vite-nunjucks-plugin": "^1.0.2",
    "@popperjs/core": "^2.11.8",
    "@types/bootstrap": "^5.2.10",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.12.4",
    "@types/ssh2": "^1.15.5",
    "@types/vue": "^2.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/tsconfig": "^0.8.1",
    "@vueuse/core": "^13.9.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "autoprefixer": "^10.5.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "electron": "^35.5.1",
    "electron-builder": "^26.0.12",
    "electron-updater": "^6.8.3",
    "jimp": "^1.6.1",
    "js-cookie": "^3.0.7",
    "jsdom": "^26.1.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "postcss": "^8.5.15",
    "sass": "^1.100.0",
    "tailwindcss": "^3.4.19",
    "to-ico": "^1.1.5",
    "typescript": "^5.9.3",
    "vite": "latest",
    "vite-plugin-files-copy": "^3.8.0",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4",
    "vue-tsc": "^3.3.2",
    "zmodem.js": "^0.1.10"
  },
  "bin": {
    "aicmd": "bin/aicmd.js"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "cpu-features",
      "ssh2",
      "node-pty",
      "electron"
    ],
    "patchedDependencies": {
      "zmodem.js": "patches/zmodem.js.patch"
    }
  }
}
